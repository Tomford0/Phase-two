{
  "name": "emergency-response-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Phase 2 Emergency Response & Dispatch Coordination System backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "lint": "eslint . --ext .ts",
    "test": "jest --runInBand"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "http-errors": "^2.0.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.0",
    "prisma": "^5.9.0",
    "socket.io": "^4.8.1",
    "@prisma/client": "^5.9.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.18",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.11.0",
    "@types/socket.io": "^3.0.2",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.4",
    "jest": "^29.6.2",
    "supertest": "^6.4.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
