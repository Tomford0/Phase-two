generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Incident {
  id            String           @id @default(uuid())
  title         String
  type          IncidentType
  status        IncidentStatus   @default(OPEN)
  notes         String?
  latitude      Float
  longitude     Float
  createdById   String
  assignedUnitId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

enum IncidentType {
  ACCIDENT
  FIRE
  MEDICAL
  SECURITY
}

enum IncidentStatus {
  OPEN
  ASSIGNED
  ENROUTE
  ARRIVED
  RESOLVED
  CLOSED
}
