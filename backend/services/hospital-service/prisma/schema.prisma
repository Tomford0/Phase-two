generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hospital {
  id             String   @id @default(uuid())
  name           String
  address        String
  bedTotal       Int
  bedAvailable   Int
  ambulanceCount Int
  updatedAt      DateTime @updatedAt
}
