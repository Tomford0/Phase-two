generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  incidents    Incident[] @relation("IncidentCreator")
}

enum UserRole {
  ADMIN
  DISPATCHER
  DRIVER
  HOSPITAL_ADMIN
}

model Incident {
  id            String      @id @default(uuid())
  title         String
  type          IncidentType
  status        IncidentStatus @default(OPEN)
  notes         String?
  latitude      Float
  longitude     Float
  createdById   String
  createdBy     User        @relation(fields: [createdById], references: [id], name: "IncidentCreator")
  assignedUnit  Vehicle?    @relation(fields: [assignedUnitId], references: [id])
  assignedUnitId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  dispatchLog   DispatchAssignment[]
}

enum IncidentType {
  ACCIDENT
  FIRE
  MEDICAL
  SECURITY
}

enum IncidentStatus {
  OPEN
  ASSIGNED
  ENROUTE
  ARRIVED
  RESOLVED
  CLOSED
}

model Vehicle {
  id           String      @id @default(uuid())
  plateNumber  String      @unique
  type         VehicleType
  status       VehicleStatus @default(AVAILABLE)
  currentLat   Float
  currentLon   Float
  lastSeenAt   DateTime?
  hospital     Hospital?   @relation(fields: [hospitalId], references: [id])
  hospitalId   String?
  locationUpdates LocationUpdate[]
  assignments  DispatchAssignment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum VehicleType {
  AMBULANCE
  FIRE_TRUCK
  POLICE_CAR
}

enum VehicleStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

model LocationUpdate {
  id        String   @id @default(uuid())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId String
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())
}

model Hospital {
  id            String   @id @default(uuid())
  name          String
  address       String
  bedTotal      Int
  bedAvailable  Int
  ambulanceCount Int
  updatedAt     DateTime @updatedAt
}

model DispatchAssignment {
  id          String        @id @default(uuid())
  incident    Incident      @relation(fields: [incidentId], references: [id])
  incidentId  String
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])
  vehicleId   String
  assignedAt  DateTime      @default(now())
  status      AssignmentStatus @default(PENDING)
}

enum AssignmentStatus {
  PENDING
  ENROUTE
  COMPLETED
  CANCELLED
}
