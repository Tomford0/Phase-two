{
  "info": {
    "name": "Emergency Response Phase 2",
    "description": "Updated Postman collection utilizing the API Gateway on port 3000 and the new Analytics Service endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"System Admin\",\n    \"email\": \"admin@emergency.local\",\n    \"password\": \"secret123\",\n    \"role\": \"ADMIN\"\n}"
            },
            "url": "http://localhost:3000/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let responseData = pm.response.json();",
                  "if(responseData.token) {",
                  "    pm.collectionVariables.set(\"token\", responseData.token);",
                  "    console.log(\"Token automatically saved to Collection Variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@emergency.local\",\n    \"password\": \"secret123\"\n}"
            },
            "url": "http://localhost:3000/auth/login"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "http://localhost:3000/auth/profile"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
